    <plugin
      filename="libgz-sim-diff-drive-system.so"
      name="gz::sim::systems::DiffDrive">

      <left_joint>flwjoint</left_joint>
      <left_joint>rlwjoint</left_joint>

      <right_joint>frwjoint</right_joint>
      <right_joint>rrwjoint</right_joint>

      <wheel_separation>0.26</wheel_separation>
      <wheel_radius>0.04</wheel_radius>

      <odom_topic>odom</odom_topic>
      <tf_topic>tf</tf_topic>
      <frame_id>base_footprint</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
      <max_linear_acceleration>2.0</max_linear_acceleration>
      <max_angular_acceleration>3.0</max_angular_acceleration>
      <update_rate>200</update_rate>
      <topic>/cmd_vel</topic>

